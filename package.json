{
  "name": "cnotify",
  "version": "1.0.0",
  "description": "Claude Code 分布式任务完成通知系统",
  "type": "module",
  "bin": {
    "cnotify": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@inquirer/confirm": "^6.0.4",
    "@inquirer/input": "^5.0.4",
    "@inquirer/number": "^4.0.4",
    "cac": "^6.7.14",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "p-retry": "^6.2.0",
    "pino": "^9.6.0",
    "proper-lockfile": "^4.0.0",
    "smol-toml": "^1.3.1",
    "ssh2": "^1.16.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ssh2": "^1.15.3",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
